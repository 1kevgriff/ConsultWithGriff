---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const pageTitle = 'FAQ | Kevin W. Griffin - .NET & Azure Expert';
const pageDescription =
  'Frequently asked questions about Kevin Griffin, .NET consulting, Azure architecture, SignalR development, and working with a 16-time Microsoft MVP.';

// FAQ data organized by category
// Answers use HTML for internal links
const faqCategories = [
  {
    name: 'About Me',
    questions: [
      {
        question: 'Who are you?',
        answer:
          "Hey, that's me! I'm a 16-time Microsoft MVP and independent consultant running Swift Kick. I've been shipping .NET apps in production for over 19 years — ASP.NET Core and Azure are my bread and butter. I also run the Hampton Roads .NET User Group (since 2009, if you can believe it) and founded RevolutionVA, the nonprofit behind Hampton Roads DevFest. <a href=\"/about\">Learn more about me</a>.",
      },
      {
        question: 'What makes you qualified for .NET and Azure consulting?',
        answer:
          "Here's the thing: I'm not just an advisor. I actively build and ship software every single day. That includes my own SaaS products running in production, not just client work. Combine that with 16 consecutive MVP awards, international speaking, and training thousands of folks through <a href=\"/courses\">SignalR Mastery</a>, and you get someone who's seen (and fixed) a lot of things that can go wrong.",
      },
      {
        question: 'What does 16 years as a Microsoft MVP actually mean?',
        answer:
          "Honestly, I'm still a little surprised each time they renew it. The MVP award recognizes contributions to the developer community — speaking, teaching, open source, community leadership. The practical benefit for you? I get early access to what Microsoft is building next and direct lines to the .NET product teams. Ask me how I know about features before they ship.",
      },
      {
        question: 'What do you specialize in?',
        answer:
          'ASP.NET Core, Azure cloud architecture, SignalR real-time apps, Vue.js frontends, and .NET modernization. I\'m particularly known for helping teams migrate legacy .NET Framework applications to modern .NET without everything catching fire in the process. <a href="/consulting">View my consulting services</a>.',
      },
      {
        question: 'How do I get in touch?',
        answer:
          'Easiest way is to <a href="https://app.onecal.io/b/kevin-griffin/chat">grab a free 30-minute discovery call</a> — no pitch, just a conversation. You can also email me at <a href="mailto:hello@consultwithgriff.com">hello@consultwithgriff.com</a>. I respond within one business day. (I actually read my email. Wild concept, I know.) <a href="/contact">More contact options here</a>.',
      },
    ],
  },
  {
    name: 'ASP.NET Core & .NET',
    questions: [
      {
        question: 'Why should I trust you with my ASP.NET Core project?',
        answer:
          "Because I've been doing this for 19 years, and I'm still doing it — not managing people who do it. I've helped teams of all sizes build, scale, and modernize their .NET applications, from scrappy startups to enterprise organizations with more red tape than code. <a href=\"/consulting\">Learn about consulting engagements</a>.",
      },
      {
        question: 'How do I modernize a legacy .NET Framework application?',
        answer:
          "Don't rewrite everything from scratch. Seriously. I recommend the Strangler Fig pattern — you migrate components incrementally while keeping your app running in production. The whole time, I'm doing risk assessments, upskilling your team on the new stack, and building test coverage so nothing silently breaks. It's less dramatic than a big-bang rewrite, but it actually works. Ask me how I know.",
      },
      {
        question: 'What architecture patterns do you recommend?',
        answer:
          "The ones your team can actually maintain after I leave. That might be Clean Architecture, Domain-Driven Design, or a modular monolith. Let's be honest — microservices are great until they're not, and I've seen too many teams adopt them because it sounds impressive rather than because it solves their problem. Context matters more than trends.",
      },
      {
        question: 'Should I use Minimal APIs or Controllers in ASP.NET Core?',
        answer:
          'It depends. (I know, everyone\'s favorite answer.) Minimal APIs are fantastic for smaller, focused services. Controllers give you more structure for larger teams and complex apps. The real answer depends on your team\'s experience and what you\'re building. I can help you figure that out through a <a href="/consulting">consulting engagement</a> or you can dig into my <a href="/articles">articles</a> on the topic.',
      },
      {
        question: 'My .NET app is slow. Can you help?',
        answer:
          "This is my favorite kind of problem because it's so satisfying to fix. I don't guess — I profile. dotTrace, PerfView, Application Insights, the works. Find the actual bottleneck, fix it, set up monitoring so it doesn't sneak back. I've seen teams spend weeks optimizing the wrong thing because they assumed instead of measured. Don't be that team.",
      },
    ],
  },
  {
    name: 'SignalR & Real-Time',
    questions: [
      {
        question: 'Why should I trust you with my SignalR implementation?',
        answer:
          "I built <a href=\"/courses\">SignalR Mastery</a> because I kept answering the same questions on every consulting gig. Thousands of developers have taken the course. I'm still building real-time features for clients every week, so this isn't theoretical knowledge — it's what I do Monday through Friday.",
      },
      {
        question: 'What is SignalR and when should I use it?',
        answer:
          "SignalR gives you real-time, bidirectional communication between your server and clients. Think live dashboards, chat, collaborative editing, instant notifications — anything where your users shouldn't have to hit refresh to see what's new. It's one of those technologies that, once you start using it, you wonder how you lived without it.",
      },
      {
        question: 'How do I scale SignalR for production?',
        answer:
          "Short answer: Azure SignalR Service. It handles connection management, load balancing, and high availability so you don't have to. For on-prem deployments (yes, those still exist), Redis backplanes work well. Either way, the key is getting your connection management right early. Don't wait until you hit 10,000 concurrent users to think about scaling. <a href=\"/consulting\">Let's talk architecture</a>.",
      },
      {
        question: 'Do you offer SignalR training?',
        answer:
          'Absolutely. <a href="/courses">SignalR Mastery</a> covers everything from "what\'s a Hub?" to streaming, authentication, and scaling with Azure SignalR Service. If your team needs something more hands-on, I do custom workshops tailored to your specific implementation. Nothing generic — we work with your actual codebase.',
      },
      {
        question: 'My SignalR connections keep dropping. Help?',
        answer:
          'I feel your pain — I\'ve debugged more SignalR connection issues than I can count. The usual suspects: transport negotiation failures, proxy or firewall interference, hub method signature mismatches, and connection lifecycle events not being handled properly. I\'ve written about the common gotchas in my <a href="/articles">articles</a>, and I\'m available for hands-on debugging through <a href="/consulting">consulting</a> if you need someone to dig in with you.',
      },
    ],
  },
  {
    name: 'Azure',
    questions: [
      {
        question: 'Why should I hire you for Azure work?',
        answer:
          "Because I've been helping teams with Azure for over a decade, and I've seen every way it can go sideways. Bad service choices, surprise bills, architectures that don't scale — I've fixed all of them. My goal is to help you avoid the costly mistakes I've watched other teams make. <a href=\"/consulting\">View Azure consulting services</a>.",
      },
      {
        question: 'How do I migrate my application to Azure?',
        answer:
          'Carefully. (That\'s only half-joking.) I start by assessing your current architecture, then we identify the right Azure services — not every service, just the ones you actually need. From there, it\'s a risk-assessed migration roadmap with multi-region strategies when appropriate. The goal is making sure your team understands the trade-offs of each choice, not just blindly following "best practices" from a Microsoft article.',
      },
      {
        question: 'My Azure bill is terrifying. Can you help?',
        answer:
          "This comes up constantly. I'll do a comprehensive cost analysis, right-size your resources (you're probably over-provisioned somewhere — most folks are), evaluate where serverless makes sense, and set up cost monitoring alerts so you don't get surprised again. The goal is building solutions that scale with your business, not your credit card.",
      },
      {
        question: 'What Azure services do you recommend for .NET apps?',
        answer:
          "It depends on what you're building, but here's my go-to toolkit: Azure App Service for web apps, Azure Functions for serverless workloads, Container Apps for containerized applications, Azure SQL and Cosmos DB for data, and Azure SignalR Service for real-time features. That said, the \"best\" combination depends entirely on your specific requirements. That's why the discovery call exists.",
      },
    ],
  },
  {
    name: 'Working Together',
    questions: [
      {
        question: 'How do I hire you?',
        answer:
          "Start with a <a href=\"https://app.onecal.io/b/kevin-griffin/chat\">free 30-minute discovery call</a>. You tell me what's broken, I tell you honestly whether I can help. No sales pitch, no pressure. If there's a fit, I'll send a clear proposal within 48 hours — fixed pricing, expected outcomes, no mystery fees.",
      },
      {
        question: 'What does working with you actually look like?',
        answer:
          "I embed with your team. Slack access, code reviews, pair programming, regular check-ins — the whole thing. I'm not the kind of consultant who shows up, drops a 50-page PDF, and vanishes. I work with your folks, not around them. And I focus on knowledge transfer the entire time, because the engagement should end with your team owning everything.",
      },
      {
        question: 'What kinds of engagements do you offer?',
        answer:
          'Three flavors: short-term projects (2-4 weeks) for architecture reviews, performance audits, or migration planning; ongoing advisory retainers for continuous guidance and code reviews; and team training workshops on .NET, Azure, SignalR, and modern development practices. Most folks start with a short-term project and then realize they want ongoing support. <a href="/consulting">View all services</a>.',
      },
      {
        question: 'How much do you charge?',
        answer:
          "Custom quotes based on scope, timeline, and engagement type. I know that's not the answer you wanted, but every project is different. I'm always transparent about pricing during the <a href=\"https://app.onecal.io/b/kevin-griffin/chat\">discovery call</a> — fixed-price projects for defined scopes, retainer arrangements for ongoing work. No surprises, no hidden fees. If the budget doesn't fit, I'll tell you upfront rather than waste your time.",
      },
      {
        question: 'Do you work remotely or on-site?',
        answer:
          "Primarily remote — I've collaborated with teams across the US and internationally. For teams that prefer face-time, I'm available for periodic on-site visits, workshops, and team events. Honestly, most of my best work happens over Slack and screen sharing. The code doesn't care where I'm sitting.",
      },
      {
        question: 'Do you do code reviews?',
        answer:
          'Yes, and I actually enjoy them. (Is that weird?) I cover architecture decisions, performance considerations, security practices, and maintainability. My reviews come with actionable recommendations, not vague suggestions like "consider refactoring." They can be part of a short-term engagement or an ongoing advisory relationship.',
      },
      {
        question: 'Will you train my team?',
        answer:
          'Absolutely. I do custom training workshops tailored to your team\'s actual needs — ASP.NET Core, Azure architecture, SignalR, modern .NET practices. My teaching approach is hands-on and practical, because nobody learns from watching me type for six hours. Your folks will build things and walk away with skills they can use immediately. <a href="/courses">View available courses</a>.',
      },
    ],
  },
  {
    name: 'Speaking & Community',
    questions: [
      {
        question: 'Are you available for speaking engagements?',
        answer:
          'Yes! I regularly speak at conferences, user groups, and corporate events. Topics include SignalR deep-dives, .NET architecture patterns, Azure best practices, and lessons learned from production systems. (The "lessons learned" talks are usually the most fun — production has a way of keeping you humble.) Check out my speaker profile at <a href="https://sessionize.com/kevingriffin">sessionize.com/kevingriffin</a>.',
      },
      {
        question: 'What courses do you offer?',
        answer:
          'My flagship is <a href="/courses">SignalR Mastery</a> — thousands of folks have taken it to learn real-time web development. I also have courses on building APIs with ASP.NET Core and monitoring with Application Insights, both free on YouTube. I keep building new content because I keep learning new things worth sharing.',
      },
      {
        question: 'Do you run any developer communities?',
        answer:
          "I've been running the Hampton Roads .NET User Group since 2009 — that's a lot of pizza and presentations. I also co-lead the Hampton Roads Azure User Group and founded RevolutionVA, the nonprofit behind Hampton Roads DevFest and RevolutionConf. Building developer communities is one of the most rewarding things I do.",
      },
      {
        question: 'Can you speak at my event?',
        answer:
          'I\'d love to! Check out my full speaker profile, session abstracts, and booking info at <a href="https://sessionize.com/kevingriffin">sessionize.com/kevingriffin</a>. My talks blend real production stories with practical advice folks can use Monday morning. And yes, I do live demos. They usually work. Usually.',
      },
    ],
  },
];

// Generate FAQPage schema
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqCategories.flatMap((cat) =>
    cat.questions.map((q) => ({
      '@type': 'Question',
      name: q.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: q.answer.replace(/<[^>]*>/g, ''), // Strip HTML for schema
      },
    }))
  ),
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <link rel="canonical" href="https://consultwithgriff.com/faq" />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Frequently Asked Questions"
    subtitle="Common questions about .NET consulting, Azure architecture, SignalR development, and working with a Microsoft MVP"
    primaryCTA={{
      text: 'Schedule a Discovery Call',
      href: 'https://app.onecal.io/b/kevin-griffin/chat',
    }}
    secondaryCTA={{ text: 'Learn More About Me', href: '/about' }}
  />

  <!-- FAQ Sections by Category -->
  {
    faqCategories.map((category, i) => (
      <section class={i % 2 === 0 ? 'py-20 bg-white' : 'py-20 bg-gray-50'}>
        <div class="container mx-auto px-4 lg:px-8">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold text-navy mb-8 text-center">{category.name}</h2>
            <dl class="space-y-6">
              {category.questions.map((q) => (
                <Card variant={i % 2 === 0 ? 'light' : 'white'} hover={false}>
                  <dt class="text-xl font-bold text-navy mb-3">
                    <span class="text-gold">Q:</span> {q.question}
                  </dt>
                  <dd class="text-gray-700 leading-relaxed">
                    <span class="font-semibold">A:</span> <Fragment set:html={q.answer} />
                  </dd>
                </Card>
              ))}
            </dl>
          </div>
        </div>
      </section>
    ))
  }

  <!-- CTA Section -->
  <section class="py-20 bg-gold">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl lg:text-4xl font-bold text-navy mb-6">Still Have Questions?</h2>
        <p class="text-xl text-navy mb-8">
          Schedule a free 30-minute discovery call to discuss your specific needs. No pitch, no
          pressure—just an honest conversation about whether I can help.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button
            href="https://app.onecal.io/b/kevin-griffin/chat"
            variant="primary"
            size="lg"
            class="!bg-navy !text-gold border-2 border-navy hover:!bg-navy-light"
          >
            Schedule a Discovery Call
          </Button>
          <Button href="/contact" variant="secondary" size="lg" class="border-navy text-navy">
            Send a Message
          </Button>
        </div>

        <p class="text-sm text-navy mt-6 opacity-80">
          Or email me directly at{' '}
          <a href="mailto:hello@consultwithgriff.com" class="underline hover:text-navy-light">
            hello@consultwithgriff.com
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
