---
import type { Ride } from '../data/coasters';

interface Props {
  rides: Ride[];
}

const { rides } = Astro.props;
---

<ul class="flex flex-wrap gap-2 list-none m-0 p-0">
  {
    rides.map((ride) => {
      const isMilestone = !!ride.milestone;
      const isDefunct = !!ride.defunct;

      const baseClasses =
        'inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm font-medium transition-colors';
      const stateClasses = isMilestone
        ? 'bg-gold/10 border-gold text-navy ring-2 ring-gold/40'
        : isDefunct
          ? 'bg-gray-50 border-gray-200 text-gray-500'
          : 'bg-white border-navy-100 text-navy hover:border-gold hover:bg-gold/5';

      return (
        <li>
          <span
            class:list={[baseClasses, stateClasses]}
            title={isDefunct ? 'No longer operating at this park' : undefined}
          >
            {isMilestone && (
              <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-gold text-navy text-[0.6rem] font-extrabold leading-none">
                {ride.milestone}
              </span>
            )}
            <span class:list={[isDefunct && 'line-through']}>{ride.name}</span>
            {ride.altName && (
              <span class="text-xs text-gray-500 italic font-normal">· {ride.altName}</span>
            )}
          </span>
        </li>
      );
    })
  }
</ul>
